      "text": "This is a complete **MVP (Minimum Viable Product)** implementation plan. Since I cannot generate a single 500-file zip archive here, I have broken this down into the **three critical layers** you need to copy-paste to get this running:\n\n1.  **The Database (Supabase SQL)**\n2.  **The Backend API (Node.js/Express with the Verification Logic)**\n3.  **The Mobile App (React Native + Expo Router)**\n\n---\n\n### Prerequisites\n1.  **Node.js** installed.\n2.  **Supabase Account** (Free tier is fine).\n3.  **TMDb API Key** (Free from themoviedb.org).\n\n---\n\n### Part 1: Database Schema (Supabase)\n\nRun this in your Supabase project\u0027s **SQL Editor**. This sets up the users, caching, and lists.\n\n```sql\n-- 1. Profiles (Linked to Auth)\ncreate table public.profiles (\n  id uuid references auth.users on delete cascade not null primary key,\n  username text unique,\n  display_name text,\n  region text default \u0027US\u0027,\n  created_at timestamp with time zone default timezone(\u0027utc\u0027::text, now())\n);\n\n-- 2. Availability Cache (The Core Engine)\ncreate table public.availability_cache (\n  id bigint generated by default as identity primary key,\n  external_id text not null, -- TMDb ID\n  media_type text not null, -- \u0027movie\u0027 or \u0027tv\u0027\n  region text not null,\n  providers jsonb not null, -- The normalized data\n  last_verified_at timestamp with time zone default timezone(\u0027utc\u0027::text, now()),\n  unique(external_id, media_type, region)\n);\n\n-- 3. Must Watch List\ncreate table public.must_watch (\n  id bigint generated by default as identity primary key,\n  user_id uuid references public.profiles(id) not null,\n  external_id text not null,\n  media_type text not null,\n  title text not null, -- Cached title for offline view\n  poster_path text,\n  status text check (status in (\u0027must_watch\u0027, \u0027watched\u0027, \u0027dropped\u0027)) default \u0027must_watch\u0027,\n  note text,\n  created_at timestamp with time zone default timezone(\u0027utc\u0027::text, now())\n);\n\n-- Enable Row Level Security (RLS)\nalter table public.profiles enable row level security;\nalter table public.must_watch enable row level security;\n\n-- Basic Policies\ncreate policy \"Public profiles are viewable by everyone.\" on profiles for select using (true);\ncreate policy \"Users can insert their own profile.\" on profiles for insert with check (auth.uid() \u003d id);\ncreate policy \"Users can view their own list.\" on must_watch for select using (auth.uid() \u003d user_id);\ncreate policy \"Users can update their own list.\" on must_watch for insert with check (auth.uid() \u003d user_id);\n```\n\n---\n\n### Part 2: Backend API (Node.js)\n\nCreate a folder `backend`. Run `npm init -y` and install:\n`npm install express cors dotenv axios @supabase/supabase-js`\n\nCreate `server.js`. This contains the **mandatory `verifyAvailability` logic**.\n\n```javascript\n// backend/server.js\nrequire(\u0027dotenv\u0027).config();\nconst express \u003d require(\u0027express\u0027);\nconst cors \u003d require(\u0027cors\u0027);\nconst axios \u003d require(\u0027axios\u0027);\nconst { createClient } \u003d require(\u0027@supabase/supabase-js\u0027);\n\nconst app \u003d express();\napp.use(cors());\napp.use(express.json());\n\n// Config\nconst TMDB_KEY \u003d process.env.TMDB_API_KEY;\nconst supabase \u003d createClient(process.env.SUPABASE_URL, process.env.SUPABASE_KEY);\nconst CACHE_TTL_HOURS \u003d 12;\n\n// --- CORE LOGIC: Verify Availability ---\nasync function verifyAvailability(externalId, type, region) {\n  // 1. Check Cache\n  const { data: cached } \u003d await supabase\n    .from(\u0027availability_cache\u0027)\n    .select(\u0027*\u0027)\n    .match({ external_id: externalId, media_type: type, region })\n    .single();\n\n  if (cached) {\n    const hoursSinceUpdate \u003d (new Date() - new Date(cached.last_verified_at)) / 36e5;\n    if (hoursSinceUpdate \u003c CACHE_TTL_HOURS) {\n      console.log(`[Cache Hit] Serving ${type}/${externalId}`);\n      return cached.providers;\n    }\n  }\n\n  console.log(`[Cache Miss/Stale] Fetching TMDb for ${type}/${externalId}`);\n\n  // 2. Fetch fresh data (No Scraping - Official API)\n  try {\n    const url \u003d `https://api.themoviedb.org/3/${type}/${externalId}/watch/providers?api_key\u003d${TMDB_KEY}`;\n    const response \u003d await axios.get(url);\n    const results \u003d response.data.results;\n    \n    // Default to empty if region not found\n    const regionalData \u003d results[region] || {};\n\n    // 3. Normalize Data (Unified Structure)\n    const providers \u003d {\n      flatrate: regionalData.flatrate || [],\n      rent: regionalData.rent || [],\n      buy: regionalData.buy || [],\n      free: regionalData.free || [],\n      link: regionalData.link || \"\"\n    };\n\n    // 4. Update Database\n    const { error } \u003d await supabase\n      .from(\u0027availability_cache\u0027)\n      .upsert({\n        external_id: String(externalId),\n        media_type: type,\n        region: region,\n        providers: providers,\n        last_verified_at: new Date()\n      }, { onConflict: \u0027external_id, media_type, region\u0027 });\n\n    if (error) console.error(\"Cache Write Error:\", error);\n\n    return providers;\n\n  } catch (err) {\n    console.error(\"Provider API Error:\", err.message);\n    return cached ? cached.providers : null; // Fallback\n  }\n}\n\n// --- ENDPOINTS ---\n\n// Search\napp.get(\u0027/api/search\u0027, async (req, res) \u003d\u003e {\n  const { query } \u003d req.query;\n  try {\n    const resp \u003d await axios.get(`https://api.themoviedb.org/3/search/multi?api_key\u003d${TMDB_KEY}\u0026query\u003d${query}`);\n    // Filter out people, only keep movie/tv\n    const results \u003d resp.data.results.filter(i \u003d\u003e i.media_type \u003d\u003d\u003d \u0027movie\u0027 || i.media_type \u003d\u003d\u003d \u0027tv\u0027);\n    res.json(results);\n  } catch (e) {\n    res.status(500).json({ error: e.message });\n  }\n});\n\n// Title Details + Availability\napp.get(\u0027/api/title/:type/:id\u0027, async (req, res) \u003d\u003e {\n  const { type, id } \u003d req.params;\n  const { region \u003d \u0027US\u0027 } \u003d req.query;\n\n  try {\n    // Parallel fetch: Metadata + Availability\n    const metadataPromise \u003d axios.get(`https://api.themoviedb.org/3/${type}/${id}?api_key\u003d${TMDB_KEY}`);\n    const availabilityPromise \u003d verifyAvailability(id, type, region);\n\n    const [metaRes, providers] \u003d await Promise.all([metadataPromise, availabilityPromise]);\n\n    res.json({\n      ...metaRes.data,\n      availability: providers\n    });\n  } catch (e) {\n    res.status(500).json({ error: e.message });\n  }\n});\n\n// Add to Must Watch\napp.post(\u0027/api/mustwatch\u0027, async (req, res) \u003d\u003e {\n  const { user_id, external_id, media_type, title, poster_path } \u003d req.body;\n  const { data, error } \u003d await supabase\n    .from(\u0027must_watch\u0027)\n    .insert([{ user_id, external_id, media_type, title, poster_path }]);\n  \n  if (error) return res.status(400).json(error);\n  res.json({ success: true });\n});\n\napp.listen(3000, () \u003d\u003e console.log(\u0027MustWatch API running on port 3000\u0027));\n```\n\n---\n\n### Part 3: Frontend (React Native + Expo Router)\n\nCreate the app: `npx create-expo-app@latest MustWatch --template tabs`\nThen install: `npm install axios`\n\n#### 1. Setup API Client (`constants/api.ts`)\nReplace `localhost` with your computer\u0027s local IP address (e.g., `192.168.1.XX`) so the phone/emulator can reach it.\n\n```typescript\nimport axios from \u0027axios\u0027;\n\n// CHANGE THIS TO YOUR LOCAL IP\nconst API_URL \u003d \u0027http://192.168.1.66:3000/api\u0027; \n\nexport const searchTitles \u003d (q: string) \u003d\u003e axios.get(`${API_URL}/search?query\u003d${q}`);\nexport const getTitleDetails \u003d (type: string, id: string) \u003d\u003e axios.get(`${API_URL}/title/${type}/${id}`);\nexport const addToMustWatch \u003d (data: any) \u003d\u003e axios.post(`${API_URL}/mustwatch`, data);\n```\n\n#### 2. Search Screen (`app/(tabs)/index.tsx`)\nCorresponds to **Screen 2** in your wireframe.\n\n```tsx\nimport React, { useState } from \u0027react\u0027;\nimport { View, TextInput, FlatList, Text, Image, TouchableOpacity, StyleSheet, ActivityIndicator } from \u0027react-native\u0027;\nimport { useRouter } from \u0027expo-router\u0027;\nimport { searchTitles } from \u0027../../constants/api\u0027;\n\nexport default function SearchScreen() {\n  const [query, setQuery] \u003d useState(\u0027\u0027);\n  const [results, setResults] \u003d useState([]);\n  const [loading, setLoading] \u003d useState(false);\n  const router \u003d useRouter();\n\n  const handleSearch \u003d async () \u003d\u003e {\n    if (!query) return;\n    setLoading(true);\n    try {\n      const res \u003d await searchTitles(query);\n      setResults(res.data);\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const renderItem \u003d ({ item }) \u003d\u003e (\n    \u003cTouchableOpacity \n      style\u003d{styles.card} \n      onPress\u003d{() \u003d\u003e router.push({ pathname: \u0027/details\u0027, params: { id: item.id, type: item.media_type } })}\n    \u003e\n      \u003cImage \n        source\u003d{{ uri: `https://image.tmdb.org/t/p/w200${item.poster_path}` }} \n        style\u003d{styles.poster} \n      /\u003e\n      \u003cView style\u003d{styles.info}\u003e\n        \u003cText style\u003d{styles.title}\u003e{item.title || item.name}\u003c/Text\u003e\n        \u003cText style\u003d{styles.meta}\u003e\n          {item.media_type.toUpperCase()} • {item.release_date?.split(\u0027-\u0027)[0] || item.first_air_date?.split(\u0027-\u0027)[0]}\n        \u003c/Text\u003e\n      \u003c/View\u003e\n    \u003c/TouchableOpacity\u003e\n  );\n\n  return (\n    \u003cView style\u003d{styles.container}\u003e\n      \u003cVie