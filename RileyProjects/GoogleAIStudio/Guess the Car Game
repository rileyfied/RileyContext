 identification skills!\u003c/p\u003e\n            \u003cdiv class\u003d\"game-length-selector\"\u003e\n                \u003clabel\u003eChoose Game Length:\u003c/label\u003e\n                \u003cbutton data-length\u003d\"20\"\u003e20 Cars\u003c/button\u003e\n                \u003cbutton data-length\u003d\"50\"\u003e50 Cars\u003c/button\u003e\n                \u003cbutton data-length\u003d\"100\"\u003e100 Cars\u003c/button\u003e\n            \u003c/div\u003e\n            \u003cbutton id\u003d\"start-game-btn\"\u003eStart Game\u003c/button\u003e\n        \u003c/div\u003e\n\n        \u003cdiv id\u003d\"game-screen\" class\u003d\"screen\"\u003e\n            \u003cdiv class\u003d\"game-info\"\u003e\n                \u003cspan id\u003d\"timer\"\u003eTime: 00:00.00\u003c/span\u003e\n                \u003cspan id\u003d\"car-counter\"\u003eCar: 0/0\u003c/span\u003e\n            \u003c/div\u003e\n            \n            \u003cdiv class\u003d\"image-display\"\u003e\n                \u003cimg id\u003d\"car-image\" src\u003d\"\" alt\u003d\"Car to identify\"\u003e\n            \u003c/div\u003e\n\n            \u003cdiv class\u003d\"controls\"\u003e\n                \u003cdiv class\u003d\"selection-group\"\u003e\n                    \u003clabel for\u003d\"make-select\"\u003eMake:\u003c/label\u003e\n                    \u003cselect id\u003d\"make-select\"\u003e\u003c/select\u003e\n                    \u003cspan class\u003d\"feedback\" id\u003d\"make-feedback\"\u003e\u003c/span\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class\u003d\"selection-group\"\u003e\n                    \u003clabel for\u003d\"color-select\"\u003eColor:\u003c/label\u003e\n                    \u003cselect id\u003d\"color-select\"\u003e\u003c/select\u003e\n                    \u003cspan class\u003d\"feedback\" id\u003d\"color-feedback\"\u003e\u003c/span\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class\u003d\"selection-group\"\u003e\n                    \u00